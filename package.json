{
  "name": "hexo-site",
  "version": "0.0.0",
  "private": true,
  "hexo": {
    "version": "8.1.1"
  },
  "scripts": {
    "serve": "hexo server",
    "build": "hexo generate",
    "clean": "hexo clean",
    "deploy": "hexo clean && hexo deploy",
    "eslint": "eslint .",
    "prepare": "husky install"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "hexo": "^8.0.0",
    "hexo-clean-css": "^2.0.0",
    "hexo-deployer-git": "^4.0.0",
    "hexo-filter-nofollow": "^2.0.2",
    "hexo-fs": "^5.0.0",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-feed": "^3.0.0",
    "hexo-generator-sitemap": "^3.0.1",
    "hexo-renderer-marked": "^7.0.0",
    "hexo-renderer-pug": "^3.0.0",
    "hexo-renderer-stylus": "^3.0.1",
    "hexo-server": "^3.0.0",
    "hexo-uglify": "^2.0.0",
    "lunr": "2.3.9",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "eslint-config-hexo": "^6.0.0",
    "husky": "^9.0.6",
    "imagemin-lint-staged": "^0.5.1",
    "lint-staged": "^16.1.6"
  },
  "lint-staged": {
    "*.{png,jpeg,jpg,gif,svg}": [
      "imagemin-lint-staged",
      "git add"
    ],
    "*.js": "eslint --fix"
  },
  "engines": {
    "node": ">=14"
  }
}